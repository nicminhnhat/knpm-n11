generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  LANDLORD
  ADMIN
}

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum RoomStatus {
  AVAILABLE
  RENTED
  HIDDEN
}

enum RoomType {
  SINGLE
  SHARED
  DORM
  APARTMENT
  OTHER
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  DELETED
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  phone              String?            @unique
  passwordHash       String
  fullName           String
  role               UserRole
  status             UserStatus         @default(ACTIVE)
  lockReason         String?
  avatarUrl          String?
  verificationStatus VerificationStatus @default(NOT_SUBMITTED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  rooms                Room[]                @relation("LandlordRooms")
  posts                Post[]                @relation("LandlordPosts")
  reports              Report[]              @relation("UserReports")
  sentMessages         Message[]             @relation("SentMessages")
  studentThreads       MessageThread[]       @relation("StudentThreads")
  landlordThreads      MessageThread[]       @relation("LandlordThreads")
  favorites            Favorite[]
  reviews              Review[]              @relation("StudentReviews")
  verificationProfiles VerificationProfile[] @relation("LandlordVerificationProfiles")
  notifications         Notification[]
  accountLogs          AccountLog[]          @relation("AccountUserLogs")
  adminLogs            AccountLog[]          @relation("AccountAdminLogs")
  passwordResetTokens  PasswordResetToken[]
}

model Room {
  id               String     @id @default(cuid())
  landlordId       String
  title            String
  description      String
  address          String
  ward             String?
  district         String?
  city             String     @default("Huế")
  latitude         Float?
  longitude        Float?
  price            Float
  area             Float
  type             RoomType   @default(SINGLE)
  status           RoomStatus @default(AVAILABLE)
  maxOccupants     Int?
  electricityPrice Float?
  waterPrice       Float?
  internetPrice    Float?
  deposit          Float?
  amenities        String[]   @default([])
  contactName      String?
  contactPhone     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  landlord User            @relation("LandlordRooms", fields: [landlordId], references: [id], onDelete: Cascade)
  images   RoomImage[]
  posts    Post[]
  favorites Favorite[]
  reviews  Review[]
  threads  MessageThread[]

  @@index([landlordId])
  @@index([status])
  @@index([district])
  @@index([price])
}

model RoomImage {
  id        String   @id @default(cuid())
  roomId    String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model Post {
  id           String     @id @default(cuid())
  landlordId   String
  roomId       String?
  title        String
  description  String
  status       PostStatus @default(PENDING)
  rejectReason String?
  publishedAt  DateTime?
  hiddenAt     DateTime?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  landlord User            @relation("LandlordPosts", fields: [landlordId], references: [id], onDelete: Cascade)
  room     Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  reports  Report[]
  threads  MessageThread[]

  @@index([landlordId])
  @@index([roomId])
  @@index([status])
}

model VerificationProfile {
  id              String             @id @default(cuid())
  landlordId      String
  fullName        String
  phone           String?
  address         String?
  documentType    String?
  documentNumber  String?
  documentUrl     String?
  note            String?
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  landlord User @relation("LandlordVerificationProfiles", fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([landlordId])
  @@index([status])
}

model MessageThread {
  id         String   @id @default(cuid())
  studentId String
  landlordId String
  postId     String?
  roomId     String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student  User      @relation("StudentThreads", fields: [studentId], references: [id], onDelete: Cascade)
  landlord User      @relation("LandlordThreads", fields: [landlordId], references: [id], onDelete: Cascade)
  post     Post?     @relation(fields: [postId], references: [id], onDelete: SetNull)
  room     Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([studentId])
  @@index([landlordId])
}

model Message {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  postId     String
  reason     String
  content    String?
  status     ReportStatus @default(PENDING)
  adminNote  String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reporter User @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([postId])
  @@index([status])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  roomId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

model Review {
  id        String   @id @default(cuid())
  studentId String
  roomId    String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  room    Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([studentId, roomId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("SYSTEM")
  title     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountLog {
  id        String   @id @default(cuid())
  userId    String
  adminId   String?
  action    String
  reason    String?
  createdAt DateTime @default(now())

  user  User  @relation("AccountUserLogs", fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AccountAdminLogs", fields: [adminId], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  otpHash   String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}
